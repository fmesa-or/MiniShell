This is a heredoc test
Line 2
EOF

wc << DELIMITER
line1
line2
line3
DELIMITER

### Output Redirection Tests
echo "test output" > /tmp/test_output.txt
cat /tmp/test_output.txt
echo "append test" >> /tmp/test_output.txt
cat /tmp/test_output.txt
rm /tmp/test_output.txt

### Multiple Redirections Tests
cat < /etc/hosts > /tmp/hosts_copy.txt
wc < /etc/passwd > /tmp/passwd_count.txt
cat /tmp/hosts_copy.txt
cat /tmp/passwd_count.txt
rm /tmp/hosts_copy.txt /tmp/passwd_count.txt

## PIPE TESTS

### Basic Pipes
