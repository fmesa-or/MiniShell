## EXTERNAL COMMANDS TESTS

### Cat Tests
cat /etc/passwd | head -3
cat nonexistent_file  # Should show error
cat < /etc/hosts
echo "test content" | cat

### WC Tests
wc /etc/passwd
echo "line1\nline2\nline3" | wc -l
ls | wc -l
wc < /etc/hosts

### Grep Tests
cat /etc/passwd | grep root
grep bash /etc/passwd
echo "hello world" | grep world
grep nonexistent /etc/passwd  # Should return no matches

## REDIRECTION TESTS

### Input Redirection Tests
wc < /etc/passwd
cat < /etc/hosts
grep root < /etc/passwd

### Heredoc Tests
